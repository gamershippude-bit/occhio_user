# Copie para .env e preencha com suas chaves reais.
# NUNCA commite o arquivo .env — ele está no .gitignore.

ZAI_API_KEY=
GLM_MODEL=glm-5
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Transcrição de voz (Whisper)
OPENAI_API_KEY=

# Síntese de voz (TTS)
ELEVENLABS_API_KEY=

# MySQL (Railway) — cadastro de rostos conhecidos
# Sem DB_HOST, rostos ficam só em memória (perdem-se ao reiniciar)
DB_HOST=
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=railway
